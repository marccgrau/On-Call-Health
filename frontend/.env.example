# ====================================
# NOTHING REQUIRED FOR LOCAL DOCKER HOSTING
# All variables have sensible defaults
# ====================================

# Backend API URLs (default: http://localhost:8000 for local development)
# For production, set to your actual API URL
# NEXT_PUBLIC_API_URL=https://api.oncallhealth.ai
# NEXT_PUBLIC_API_BASE_URL=https://api.oncallhealth.ai

# ====================================
# OPTIONAL - Only if using these services
# ====================================

# New Relic Browser Monitoring (Optional)
# Get these values from New Relic UI > Browser > (your app) > Application settings
NEXT_PUBLIC_NEW_RELIC_ACCOUNT_ID=
NEXT_PUBLIC_NEW_RELIC_TRUST_KEY=
NEXT_PUBLIC_NEW_RELIC_AGENT_ID=
NEXT_PUBLIC_NEW_RELIC_LICENSE_KEY=
NEXT_PUBLIC_NEW_RELIC_APPLICATION_ID=

# Integration Client IDs (optional - only needed for OAuth flows)
NEXT_PUBLIC_SLACK_CLIENT_ID=
NEXT_PUBLIC_JIRA_CLIENT_ID=

# Optional - enable the Okta SSO button for self-hosted or dedicated enterprise deployments
NEXT_PUBLIC_ENABLE_OKTA_SSO=false

# Google Analytics (Optional)
# We use analytics to understand how the tool is used and improve it.
# If you'd like to help us improve the project, you can enable analytics
# by setting our measurement ID: G-VMJT128VZS
# You can also use your own GA4 measurement ID if you prefer.
# Leave empty to disable analytics (default).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
