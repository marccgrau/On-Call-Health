# Base image with Node dependencies pre-installed
# Build: docker build -f Dockerfile.base -t rootlyio/on-call-health:frontend-base .
# Push:  docker push rootlyio/on-call-health:frontend-base

FROM oven/bun:1.2-alpine AS base

WORKDIR /app

# Copy package files and install dependencies
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile && \
    rm -rf ~/.bun/install/cache

# Dependencies are now in /app/node_modules
