# E2E Test Environment Variables
# Copy this file to .env.test and fill in your test credentials

# Test account credentials (do not commit real values)
# Obtain these from your team or GitHub Secrets
E2E_TEST_EMAIL=your-test-email@example.com
E2E_TEST_PASSWORD=your-test-password-here

# API URL for E2E tests (defaults to localhost:8000)
PLAYWRIGHT_API_URL=http://localhost:8000

# Frontend URL for E2E tests (defaults to localhost:3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000
