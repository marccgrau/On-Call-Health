# ====================================
# REQUIRED FOR LOCAL DOCKER HOSTING
# ====================================

# Database (PostgreSQL) - REQUIRED
# For Docker Compose, use the postgres service name:
DATABASE_URL=postgresql://postgres:password@postgres:5432/burnout_detector

# JWT Secret - REQUIRED
# Used to sign JWT authentication tokens
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Token Encryption - REQUIRED
# Used to encrypt OAuth tokens stored in the database
# For local development: Generate your own key with: openssl rand -base64 32
# For production/staging: Use the environment-specific key (stored in Railway)
# IMPORTANT: Changing this key will break all existing OAuth integrations in that environment
ENCRYPTION_KEY=

# ====================================
# OPTIONAL - Only if using integrations
# ====================================

# Google OAuth (optional - only if using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional - only if using GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Jira OAuth (optional - only if using Jira integration)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Linear OAuth (optional - only if using Linear integration)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Redis (optional - for rate limiting in production)
REDIS_URL=redis://localhost:6379/1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# ====================================
# HAS DEFAULTS - Override only if needed
# ====================================

# Frontend URL (default: http://localhost:3000)
# FRONTEND_URL=http://localhost:3000

# Environment (default: development)
# ENVIRONMENT=development

# Log Level (default: INFO)
# Available: DEBUG, INFO, WARNING, ERROR, CRITICAL
# For production/Railway, use WARNING to reduce log verbosity
# LOG_LEVEL=INFO

# Rootly API (default: https://api.rootly.com)
# ROOTLY_API_BASE_URL=https://api.rootly.com

# Working Hours Configuration
# These define what is considered "business hours" for burnout analysis
# Hours are in 24-hour format (0-23) and applied in each user's local timezone
# User timezones are automatically fetched from Rootly/PagerDuty profiles
# BUSINESS_HOURS_START=9
# BUSINESS_HOURS_END=17
# LATE_NIGHT_START=22
# LATE_NIGHT_END=6

# Rate limiting bypass for development (default: false)
# BYPASS_RATE_LIMITING=false
